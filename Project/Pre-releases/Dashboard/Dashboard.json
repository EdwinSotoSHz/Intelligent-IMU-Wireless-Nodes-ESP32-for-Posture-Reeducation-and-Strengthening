        "func": "// Asegurar que payload sea objeto\nlet data = msg.payload;\n\nif (typeof data === \"string\") {\n    try {\n        data = JSON.parse(data);\n    } catch (e) {\n        node.error(\"No es .json\");\n        return null;\n    }\n}\n\n// Salidas\nreturn [\n    { topic: \"ecg\", payload: data.ecg },\n    { topic: \"roll_a\", payload: data.roll_a },\n    { topic: \"pitch_a\", payload: data.pitch_a },\n    { topic: \"yaw_a\", payload: data.yaw_a },\n    { topic: \"roll_f\", payload: data.roll_f },\n    { topic: \"pitch_f\", payload: data.pitch_f },\n    { topic: \"yaw_f\", payload: data.yaw_f }\n];",
