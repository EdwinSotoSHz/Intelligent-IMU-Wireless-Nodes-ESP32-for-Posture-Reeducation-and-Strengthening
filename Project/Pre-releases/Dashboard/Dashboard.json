    {
        "id": "8932a8c9c6edbb67",
        "type": "function",
        "z": "e93020d1f28ab3b8",
        "d": true,
        "name": "ecg to indicator",
        "func": "let valor = msg.payload;\nlet nivel = \"\";\n\n// Clasificación basada en tus promedios\nif (valor >= 2050 && valor < 2450) {\n    msg.payload = 1;\n    nivel = \"REPOSO\";\n} else if (valor >= 1600 && valor < 3050) {\n    msg.payload = 2;\n    nivel = \"FLEXIÓN LEVE\";\n} else if (valor >= 20 && valor <= 3300) {\n    msg.payload = 3;\n    nivel = \"MOVIMIENTO FUERTE\";\n} else {\n    msg.payload = 0;\n    nivel = \"RUIDO\";\n}\n\nmsg.ui_update = {\n    title: nivel\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1160,
        "y": 180,
        "wires": [
            [
                "7aea458fd07fde45"
            ]
        ]
    },
    {
        "id": "6140627a9ee5ffcb",
        "type": "function",
        "z": "e93020d1f28ab3b8",
        "d": true,
        "name": "ecg to percentage",
        "func": "// =============================================\n// CONFIGURACIÓN BASADA EN TUS CAPTURAS\n// =============================================\nconst OFFSET = 2250;      // El centro de tu señal en reposo\nconst NOISE_FLOOR = 250;  // Amplitud de ruido (Rango dinámico reposo / 2)\nconst MAX_AMP = 1600;     // Amplitud máxima (Rango dinámico fuerte / 2)\n\n// Suavizado para que el porcentaje no salte (0.05 muy suave - 0.2 más rápido)\nconst ALPHA = 0.1; \n\n// =============================================\n// 1. CÁLCULO DE LA AMPLITUD INSTANTÁNEA\n// =============================================\n// Medimos qué tan lejos está el punto actual del centro (2250)\nlet amplitudInstante = Math.abs(msg.payload - OFFSET);\n\n// =============================================\n// 2. FILTRO DE ENVOLVENTE (Smoothing)\n// =============================================\ncontext.env = context.env || 0;\ncontext.env = (ALPHA * amplitudInstante) + (1 - ALPHA) * context.env;\n\n// =============================================\n// 3. CONVERSIÓN A PORCENTAJE REAL\n// =============================================\n// Restamos el ruido base para que en reposo marque 0%\nlet señalLimpia = context.env - NOISE_FLOOR;\nif (señalLimpia < 0) señalLimpia = 0;\n\n// Calculamos el porcentaje respecto al máximo alcanzado en tus pruebas\nlet porcentaje = (señalLimpia / (MAX_AMP - NOISE_FLOOR)) * 100;\n\n// Limitar entre 0 y 100 y redondear\nmsg.payload = Math.round(Math.min(Math.max(porcentaje, 0), 100));\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1150,
        "y": 120,
        "wires": [
            [
                "beb758a44254f859"
            ]
        ]
    },
